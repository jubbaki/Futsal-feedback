# 관리자 페이지 비밀번호 (코드에 넣지 말고 여기서만 관리)
ADMIN_PASSWORD=0413

# 코치님 페이지 URL 토큰 — /coach/<이 값> 으로 접속
# 긴 랜덤 문자열 권장. 생성 예: openssl rand -hex 24
COACH_SHARE_TOKEN=change-me-to-a-long-random-token

# 관리자 세션 쿠키 서명용 비밀키. 생성 예: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret

# Supabase 프로젝트 설정 (Settings → API)
# 비워두면 개발용 메모리 저장소로 동작 (서버 재시작 시 데이터 사라짐)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
